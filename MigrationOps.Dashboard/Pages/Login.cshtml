@page
@model MigrationOps.Dashboard.Pages.LoginModel
@{
    ViewData["Title"] = "Log in";
}
<div class="auth-shell">
    <div class="auth-card">
        <h1><span class="brand-chevron">&gt;_</span> Migration<span class="brand-ops">Ops</span></h1>
        <p class="subtitle">Sign in to view migration status.</p>

        @if (Model.Error != null)
        {
            <div class="validation-summary">@Model.Error</div>
        }

        <form method="post">
            <div class="field">
                <label for="Username">Username</label>
                <input type="text" id="Username" name="Username" autocomplete="username" required />
            </div>
            <div class="field">
                <label for="Password">Password</label>
                <input type="password" id="Password" name="Password" autocomplete="current-password" required />
            </div>
            <button type="submit" class="btn-primary">Log in</button>
        </form>
    </div>
</div>

@page
@model MigrationOps.Dashboard.Pages.DryRunModel
@{
    ViewData["Title"] = "Dry-run";

    var pendingCount = Model.Plan.Entries.Count(e => e.Status == PlanEntryStatus.WouldApply);
    var changedCount = Model.Plan.Entries.Count(e => e.Status == PlanEntryStatus.Changed);
    var errorCount = Model.Plan.Entries.Count(e => e.Status == PlanEntryStatus.ValidationError);
    var verifyFailedCount = Model.Plan.Entries.Count(e => e.VerifyStatus == PlanEntryStatus.VerifyFailed);
}

<div class="panel">
    <h2>Dry-run</h2>
    <p class="text-secondary" style="font-size:0.85rem; margin:0 0 14px;">
        Read-only preview of what a real run would do &mdash; the dashboard equivalent of
        <span class="mono">dotnet run -- dry-run</span>. Verify additionally executes the pending
        scripts in one transaction per database and always rolls back; nothing is ever committed.
    </p>

    <div class="filter-bar">
        <form method="get" class="filter-bar" style="margin:0;">
            <select name="database">
                <option value="">All databases</option>
                @foreach (var db in Model.DatabaseNames)
                {
                    <option value="@db" selected="@(string.Equals(db, Model.Database, StringComparison.OrdinalIgnoreCase))">@db</option>
                }
            </select>
            <button type="submit" class="theme-toggle"
                    title="Read-only report: classifies every script as already applied, would apply, CHANGED, or error by comparing files against the history tables. Never executes your SQL.">
                Run dry-run
            </button>
        </form>
        <form method="post" asp-page-handler="Verify" class="filter-bar" style="margin:0;">
            <input type="hidden" name="database" value="@Model.Database" />
            <button type="submit" class="theme-toggle"
                    title="Same report, but also executes the pending scripts in one transaction per database and always rolls back — proves the SQL runs cleanly without committing anything. Takes real locks while it runs.">
                Run with verify
            </button>
        </form>
    </div>
</div>

<div class="result-banner @(Model.Succeeded ? "good" : "bad")">
    @if (Model.Succeeded)
    {
        <span>DRY-RUN SUCCEEDED &mdash; nothing blocking a real run@(Model.VerifyRan ? " (verify passed)" : "")</span>
    }
    else
    {
        <span>DRY-RUN FAILED &mdash; @changedCount changed, @errorCount error(s)@(Model.VerifyRan ? $", {verifyFailedCount} verify failure(s)" : "")</span>
    }
</div>

<div class="tile-grid">
    <div class="tile">
        <div class="tile-label">Databases targeted</div>
        <div class="tile-value">@Model.Plan.TargetDatabases.Count</div>
    </div>
    <div class="tile tile-warning">
        <div class="tile-label">Would apply</div>
        <div class="tile-value">@pendingCount</div>
    </div>
    <div class="tile tile-critical">
        <div class="tile-label">Changed (edited applied migration)</div>
        <div class="tile-value">@changedCount</div>
    </div>
    <div class="tile tile-critical">
        <div class="tile-label">Validation errors</div>
        <div class="tile-value">@errorCount</div>
    </div>
    @if (Model.VerifyRan)
    {
        <div class="tile tile-critical">
            <div class="tile-label">Verify failures</div>
            <div class="tile-value">@verifyFailedCount</div>
        </div>
    }
</div>

@foreach (var group in Model.Groups)
{
    var entries = Model.EntriesFor(group);
    <div class="panel">
        <h2 class="mono">@group</h2>

        @if (entries.Count == 0)
        {
            <p class="text-muted" style="margin:0;">(nothing to do)</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>File</th>
                        <th>Kind</th>
                        <th>Status</th>
                        <th>Detail</th>
                        @if (Model.VerifyRan)
                        {
                            <th>Verify</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in entries)
                    {
                        <tr>
                            <td class="mono">@entry.FileName</td>
                            <td class="text-muted">@(entry.Kind == ScriptKind.Migration ? "migration" : "object")</td>
                            <td>
                                @switch (entry.Status)
                                {
                                    case PlanEntryStatus.AlreadyApplied:
                                        <span class="status-badge status-success">Already applied</span>
                                        break;
                                    case PlanEntryStatus.WouldApply:
                                        <span class="status-badge status-pending">Would apply</span>
                                        break;
                                    case PlanEntryStatus.Changed:
                                        <span class="status-badge status-drift">CHANGED</span>
                                        break;
                                    default:
                                        <span class="status-badge status-failed">Error</span>
                                        break;
                                }
                            </td>
                            <td class="text-muted">
                                @entry.Detail
                                @if (entry.Status == PlanEntryStatus.Changed && entry.Kind == ScriptKind.Migration)
                                {
                                    <div class="warning-note">
                                        A real run would re-execute this migration. Applied migrations must
                                        never be edited; put the fix in a new migration.
                                    </div>
                                }
                            </td>
                            @if (Model.VerifyRan)
                            {
                                <td>
                                    @if (entry.VerifyStatus == PlanEntryStatus.VerifyPassed)
                                    {
                                        <span class="status-badge status-success">Passed</span>
                                    }
                                    else if (entry.VerifyStatus == PlanEntryStatus.VerifyFailed)
                                    {
                                        <span class="status-badge status-failed">Failed</span>
                                        <div class="error-text">@entry.VerifyDetail</div>
                                    }
                                    else if (entry.VerifyStatus == PlanEntryStatus.NotVerified)
                                    {
                                        <span class="text-muted">@(entry.VerifyDetail ?? "not verified")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">&mdash;</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

            var summary =
                $"{entries.Count(e => e.Status == PlanEntryStatus.AlreadyApplied)} applied, " +
                $"{entries.Count(e => e.Status == PlanEntryStatus.WouldApply)} pending, " +
                $"{entries.Count(e => e.Status == PlanEntryStatus.Changed)} changed, " +
                $"{entries.Count(e => e.Status == PlanEntryStatus.ValidationError)} errors";

            if (Model.VerifyRan && entries.Any(e => e.VerifyStatus != null))
            {
                summary +=
                    $"   (verify: {entries.Count(e => e.VerifyStatus == PlanEntryStatus.VerifyPassed)} passed, " +
                    $"{entries.Count(e => e.VerifyStatus == PlanEntryStatus.VerifyFailed)} failed, " +
                    $"{entries.Count(e => e.VerifyStatus == PlanEntryStatus.NotVerified)} not verified)";
            }

            <p class="text-muted" style="font-size:0.8rem; margin:12px 0 0;">@summary</p>
        }
    </div>
}

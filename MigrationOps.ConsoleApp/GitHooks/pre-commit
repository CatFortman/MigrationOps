#!/bin/sh

# Checksums are computed from file content at apply/plan time (see
# MigrationService.ComputeChecksum) instead of being trusted from a header
# here, so this hook only validates that every staged .sql file declares its
# target databases.
tag_pattern="^--\s*Tags\s*:\s*(.+)$"

sql_files=$(git diff --cached --name-only --diff-filter=ACMR | grep '.sql$')

for file in $sql_files; do
    if ! grep -qE "$tag_pattern" "$file"; then
        echo "Error: $file has incorrect or missing tag format. Ensure '-- Tags: <database name>' format. Example: '-- Tags: db1'."
        exit 1
    fi
done

exit 0
